#!/usr/bin/env bash

set -euo pipefail

CHART_PATH="./helm"
INSTANCES_DIR="./instances"

# Convert CPU to millicores
cpu_to_m() {
  local cpu="$1"
  if [[ "$cpu" == *m ]]; then
    echo "${cpu%m}"
  else
    echo "$((cpu * 1000))"
  fi
}

# Convert memory to Mi
mem_to_mi() {
  local mem="$1"
  if [[ "$mem" == *Gi ]]; then
    echo "$(( ${mem%Gi} * 1024 ))"
  elif [[ "$mem" == *Mi ]]; then
    echo "${mem%Mi}"
  else
    echo "0"
  fi
}

process_instance() {
  local env="$1"
  local instance="$2"
  local values_file="$3"

  echo "=============================="
  echo "Instance: $instance ($env)"
  echo "=============================="

  # Render Helm (MERGE effectué ici)
  rendered=$(helm template "$instance" "$CHART_PATH" \
    -f "$CHART_PATH/values.yaml" \
    -f "$values_file")

  total_cpu=0
  total_mem=0

  echo "$rendered" | yq -o=json '.' | jq -c '
    .[] | select(.kind == "Deployment" or .kind == "StatefulSet")
  ' | while read -r workload; do

    name=$(echo "$workload" | jq -r '.metadata.name')

    replicas=$(echo "$workload" | jq -r '
      if .spec.replicas then .spec.replicas else 1 end
    ')

    # autoscaling fallback
    if [[ "$replicas" == "null" ]]; then
      replicas=1
    fi

    containers=$(echo "$workload" | jq -c '.spec.template.spec.containers[]')

    container_count=$(echo "$containers" | wc -l)

    pod_cpu=0
    pod_mem=0

    while read -r c; do
      cpu=$(echo "$c" | jq -r '.resources.requests.cpu // "0"')
      mem=$(echo "$c" | jq -r '.resources.requests.memory // "0"')

      cpu_m=$(cpu_to_m "$cpu")
      mem_mi=$(mem_to_mi "$mem")

      pod_cpu=$((pod_cpu + cpu_m))
      pod_mem=$((pod_mem + mem_mi))

    done <<< "$containers"

    total_workload_cpu=$((pod_cpu * replicas))
    total_workload_mem=$((pod_mem * replicas))

    total_cpu=$((total_cpu + total_workload_cpu))
    total_mem=$((total_mem + total_workload_mem))

    echo "→ $name"
    echo "  replicas: $replicas"
    echo "  containers: $container_count"
    echo "  cpu: ${total_workload_cpu}m"
    echo "  memory: ${total_workload_mem}Mi"
    echo ""

  done

  echo "TOTAL Instance $instance:"
  echo "CPU: ${total_cpu}m"
  echo "Memory: ${total_mem}Mi"
  echo ""
}

# MAIN LOOP
for env in nprd prod; do
  echo "################################"
  echo "ENV: $env"
  echo "################################"

  for instance_dir in "$INSTANCES_DIR/$env"/*; do
    instance=$(basename "$instance_dir")
    values_file="$instance_dir/values.yaml"

    if [[ -f "$values_file" ]]; then
      process_instance "$env" "$instance" "$values_file"
    fi
  done
done
