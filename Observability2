#!/usr/bin/env bash

set -euo pipefail

CHART_PATH="./helm"
INSTANCES_DIR="./instances"

# -----------------------------
# Convert CPU → millicores
# -----------------------------
cpu_to_m() {
  local cpu="$1"
  if [[ "$cpu" == *m ]]; then
    echo "${cpu%m}"
  elif [[ "$cpu" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    echo "$(awk "BEGIN {print int($cpu * 1000)}")"
  else
    echo "0"
  fi
}

# -----------------------------
# Convert memory → Mi
# -----------------------------
mem_to_mi() {
  local mem="$1"
  if [[ "$mem" == *Gi ]]; then
    echo "$(( ${mem%Gi} * 1024 ))"
  elif [[ "$mem" == *Mi ]]; then
    echo "${mem%Mi}"
  else
    echo "0"
  fi
}

# -----------------------------
# Get resource (requests -> limits fallback)
# -----------------------------
get_cpu() {
  echo "$1" | jq -r '
    .requests.cpu // .limits.cpu // "0"
  '
}

get_mem() {
  echo "$1" | jq -r '
    .requests.memory // .limits.memory // "0"
  '
}

# -----------------------------
# Process ArgoCD CR
# -----------------------------
process_instance() {
  local env="$1"
  local instance="$2"
  local values_file="$3"

  echo "=============================="
  echo "Instance: $instance ($env)"
  echo "=============================="

  rendered=$(helm template "$instance" "$CHART_PATH" \
    -f "$CHART_PATH/values.yaml" \
    -f "$values_file")

  total_cpu=0
  total_mem=0

  echo "$rendered" | yq -o=json '.' | jq -c '
    if type == "array" then .[] else . end
    | select(.kind == "ArgoCD")
  ' | while read -r cr; do

    # -----------------------------
    # CONTROLLER
    # -----------------------------
    ctrl=$(echo "$cr" | jq '.spec.controller.resources // {}')
    ctrl_replicas=$(echo "$cr" | jq -r '.spec.controller.sharding.replicas // 1')

    cpu=$(get_cpu "$ctrl")
    mem=$(get_mem "$ctrl")

    cpu_m=$(cpu_to_m "$cpu")
    mem_mi=$(mem_to_mi "$mem")

    total_ctrl_cpu=$((cpu_m * ctrl_replicas))
    total_ctrl_mem=$((mem_mi * ctrl_replicas))

    echo "→ controller"
    echo "  replicas: $ctrl_replicas"
    echo "  cpu: ${total_ctrl_cpu}m"
    echo "  memory: ${total_ctrl_mem}Mi"

    total_cpu=$((total_cpu + total_ctrl_cpu))
    total_mem=$((total_mem + total_ctrl_mem))

    # -----------------------------
    # REPO SERVER
    # -----------------------------
    repo=$(echo "$cr" | jq '.spec.repo.resources // {}')
    repo_replicas=$(echo "$cr" | jq -r '.spec.repo.replicas // 1')

    cpu=$(get_cpu "$repo")
    mem=$(get_mem "$repo")

    cpu_m=$(cpu_to_m "$cpu")
    mem_mi=$(mem_to_mi "$mem")

    total_repo_cpu=$((cpu_m * repo_replicas))
    total_repo_mem=$((mem_mi * repo_replicas))

    echo "→ repoServer"
    echo "  replicas: $repo_replicas"
    echo "  cpu: ${total_repo_cpu}m"
    echo "  memory: ${total_repo_mem}Mi"

    total_cpu=$((total_cpu + total_repo_cpu))
    total_mem=$((total_mem + total_repo_mem))

    # -----------------------------
    # SERVER (autoscaling aware)
    # -----------------------------
    server=$(echo "$cr" | jq '.spec.server.resources // {}')

    server_replicas=$(echo "$cr" | jq -r '
      .spec.server.replicas //
      .spec.server.autoscaling.minReplicas //
      1
    ')

    cpu=$(get_cpu "$server")
    mem=$(get_mem "$server")

    cpu_m=$(cpu_to_m "$cpu")
    mem_mi=$(mem_to_mi "$mem")

    total_srv_cpu=$((cpu_m * server_replicas))
    total_srv_mem=$((mem_mi * server_replicas))

    echo "→ server"
    echo "  replicas: $server_replicas"
    echo "  cpu: ${total_srv_cpu}m"
    echo "  memory: ${total_srv_mem}Mi"

    total_cpu=$((total_cpu + total_srv_cpu))
    total_mem=$((total_mem + total_srv_mem))

    # -----------------------------
    # REDIS (HA support simple)
    # -----------------------------
    redis=$(echo "$cr" | jq '.spec.redis.resources // {}')
    redis_replicas=$(echo "$cr" | jq -r '.spec.redis.replicas // 1')

    # 👉 tweak ici si redis-ha (ex: 3 pods * 2 containers)
    redis_container_count=1

    cpu=$(get_cpu "$redis")
    mem=$(get_mem "$redis")

    cpu_m=$(cpu_to_m "$cpu")
    mem_mi=$(mem_to_mi "$mem")

    total_redis_cpu=$((cpu_m * redis_replicas * redis_container_count))
    total_redis_mem=$((mem_mi * redis_replicas * redis_container_count))

    echo "→ redis"
    echo "  replicas: $redis_replicas"
    echo "  containers: $redis_container_count"
    echo "  cpu: ${total_redis_cpu}m"
    echo "  memory: ${total_redis_mem}Mi"

    total_cpu=$((total_cpu + total_redis_cpu))
    total_mem=$((total_mem + total_redis_mem))

  done

  echo ""
  echo "TOTAL Instance $instance:"
  echo "CPU: ${total_cpu}m"
  echo "Memory: ${total_mem}Mi"
  echo ""
}

# -----------------------------
# MAIN LOOP
# -----------------------------
for env in nprd prod; do
  echo "################################"
  echo "ENV: $env"
  echo "################################"

  for instance_dir in "$INSTANCES_DIR/$env"/*; do
    instance=$(basename "$instance_dir")
    values_file="$instance_dir/values.yaml"

    if [[ -f "$values_file" ]]; then
      process_instance "$env" "$instance" "$values_file"
    fi
  done
done
