#!/bin/bash

set -euo pipefail

ROOT_DIR="${1:-instances}"

# -------- helpers --------
to_mcpu() {
  local v="$1"
  [[ -z "$v" ]] && echo 0 && return
  if [[ "$v" == *m ]]; then
    echo "${v%m}"
  else
    echo "$(echo "$v * 1000" | bc)"
  fi
}

to_mi() {
  local v="$1"
  [[ -z "$v" ]] && echo 0 && return
  if [[ "$v" == *Gi ]]; then
    echo "$(echo "${v%Gi} * 1024" | bc)"
  elif [[ "$v" == *Mi ]]; then
    echo "${v%Mi}"
  else
    echo "$v"
  fi
}

get() {
  yq "$1 // \"\"" "$2"
}

# -------- totals --------
GLOBAL_MIN_CPU=0
GLOBAL_MAX_CPU=0
GLOBAL_MIN_MEM=0
GLOBAL_MAX_MEM=0

echo "Scanning: $ROOT_DIR"
echo ""

find "$ROOT_DIR" -name values.yaml | while read -r FILE; do

  # -------- CONTROLLER --------
  ctrl_cpu=$(get '.controller.resources.requests.cpu' "$FILE")
  ctrl_mem=$(get '.controller.resources.requests.memory' "$FILE")

  ctrl_rep=$(get '.controller.sharding.replicas' "$FILE")
  [[ -z "$ctrl_rep" ]] && ctrl_rep=$(get '.controller.replicas' "$FILE")
  [[ -z "$ctrl_rep" ]] && ctrl_rep=1

  # -------- REPO --------
  repo_cpu=$(get '.repoServer.resources.requests.cpu' "$FILE")
  repo_mem=$(get '.repoServer.resources.requests.memory' "$FILE")
  repo_rep=$(get '.repoServer.replicas' "$FILE")
  [[ -z "$repo_rep" ]] && repo_rep=1

  # -------- SERVER --------
  srv_cpu=$(get '.server.resources.requests.cpu' "$FILE")
  srv_mem=$(get '.server.resources.requests.memory' "$FILE")

  hpa_enabled=$(get '.server.autoscaling.enabled' "$FILE')

  if [[ "$hpa_enabled" == "true" ]]; then
    srv_min=$(get '.server.autoscaling.hpa.minReplicas' "$FILE")
    srv_max=$(get '.server.autoscaling.hpa.maxReplicas' "$FILE")
  else
    srv_min=$(get '.server.replicas' "$FILE")
    srv_max="$srv_min"
  fi

  [[ -z "$srv_min" ]] && srv_min=1
  [[ -z "$srv_max" ]] && srv_max=1

  # -------- convert --------
  ctrl_cpu_m=$(to_mcpu "$ctrl_cpu")
  ctrl_mem_mi=$(to_mi "$ctrl_mem")

  repo_cpu_m=$(to_mcpu "$repo_cpu")
  repo_mem_mi=$(to_mi "$repo_mem")

  srv_cpu_m=$(to_mcpu "$srv_cpu")
  srv_mem_mi=$(to_mi "$srv_mem")

  # -------- totals per instance --------
  MIN_CPU=$(( ctrl_cpu_m*ctrl_rep + repo_cpu_m*repo_rep + srv_cpu_m*srv_min ))
  MAX_CPU=$(( ctrl_cpu_m*ctrl_rep + repo_cpu_m*repo_rep + srv_cpu_m*srv_max ))

  MIN_MEM=$(( ctrl_mem_mi*ctrl_rep + repo_mem_mi*repo_rep + srv_mem_mi*srv_min ))
  MAX_MEM=$(( ctrl_mem_mi*ctrl_rep + repo_mem_mi*repo_rep + srv_mem_mi*srv_max ))

  # -------- print instance --------
  echo "----------------------------------------"
  echo "Instance: $FILE"
  printf "CPU  min/max: %6sm / %6sm\n" "$MIN_CPU" "$MAX_CPU"
  printf "MEM  min/max: %6sMi / %6sMi\n" "$MIN_MEM" "$MAX_MEM"

  # -------- accumulate --------
  GLOBAL_MIN_CPU=$((GLOBAL_MIN_CPU + MIN_CPU))
  GLOBAL_MAX_CPU=$((GLOBAL_MAX_CPU + MAX_CPU))

  GLOBAL_MIN_MEM=$((GLOBAL_MIN_MEM + MIN_MEM))
  GLOBAL_MAX_MEM=$((GLOBAL_MAX_MEM + MAX_MEM))

done

echo ""
echo "============== GLOBAL =============="
printf "CPU MIN: %sm (%.2f cores)\n" "$GLOBAL_MIN_CPU" "$(echo "$GLOBAL_MIN_CPU/1000" | bc -l)"
printf "CPU MAX: %sm (%.2f cores)\n" "$GLOBAL_MAX_CPU" "$(echo "$GLOBAL_MAX_CPU/1000" | bc -l)"

printf "MEM MIN: %s Mi (%.2f Gi)\n" "$GLOBAL_MIN_MEM" "$(echo "$GLOBAL_MIN_MEM/1024" | bc -l)"
printf "MEM MAX: %s Mi (%.2f Gi)\n" "$GLOBAL_MAX_MEM" "$(echo "$GLOBAL_MAX_MEM/1024" | bc -l)"
echo "===================================="
