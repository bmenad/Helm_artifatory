#!/usr/bin/env bash
set -euo pipefail

GLOBAL_VALUES="helm/values.yaml"
ENVS=("nprd" "prod" "staging")

TOTAL_MIN_CPU=0
TOTAL_MIN_MEM=0
TOTAL_MAX_CPU=0
TOTAL_MAX_MEM=0

cpu_to_m() {
  case "$1" in
    *m) echo "${1%m}" ;;
    ""|"null") echo 0 ;;
    *) echo "$(echo "$1 * 1000" | bc)" ;;
  esac
}

mem_to_mi() {
  case "$1" in
    *Gi) echo "$(echo "${1%Gi} * 1024" | bc)" ;;
    *Mi) echo "${1%Mi}" ;;
    ""|"null") echo 0 ;;
    *) echo 0 ;;
  esac
}

# đź”Ą NOUVELLE LOGIQUE compatible old + new chart
get_resources() {
  local file="$1"
  local comp="$2"

  # size (nouvelle chart)
  size=$(yq eval ".${comp}.size // \"null\"" "$file")

  # base (ancienne chart + fallback)
  base_cpu=$(yq eval ".${comp}.resources.requests.cpu // \"null\"" "$file")
  base_mem=$(yq eval ".${comp}.resources.requests.memory // \"null\"" "$file")

  cpu="$base_cpu"
  mem="$base_mem"

  # size layer (nouvelle chart)
  if [[ "$size" != "null" ]]; then
    size_cpu=$(yq eval ".sizes.${size}.${comp}.resources.requests.cpu // \"null\"" "$file")
    size_mem=$(yq eval ".sizes.${size}.${comp}.resources.requests.memory // \"null\"" "$file")

    [[ "$size_cpu" != "null" ]] && cpu="$size_cpu"
    [[ "$size_mem" != "null" ]] && mem="$size_mem"
  fi

  # override explicite (prioritĂ© max)
  override_cpu=$(yq eval ".${comp}.resources.requests.cpu // \"null\"" "$file")
  override_mem=$(yq eval ".${comp}.resources.requests.memory // \"null\"" "$file")

  [[ "$override_cpu" != "null" ]] && cpu="$override_cpu"
  [[ "$override_mem" != "null" ]] && mem="$override_mem"

  echo "${cpu:-0} ${mem:-0}"
}

get_counts() {
  local file="$1"
  local comp="$2"

  min=$(yq eval ".${comp}.autoscaling.hpa.minReplicas" "$file")
  max=$(yq eval ".${comp}.autoscaling.hpa.maxReplicas" "$file")
  replicas=$(yq eval ".${comp}.replicas" "$file")

  sharding_enabled=$(yq eval ".${comp}.sharding.enabled // \"false\"" "$file")
  sharding_replicas=$(yq eval ".${comp}.sharding.replicas" "$file")

  if [[ "$sharding_enabled" == "true" && "$sharding_replicas" != "null" ]]; then
    replicas=$sharding_replicas
  fi

  [[ "$replicas" == "null" ]] && replicas=1

  if [[ "$min" != "null" ]]; then
    min_count=$min
    [[ "$max" == "null" ]] && max=$min
    max_count=$max
  else
    min_count=$replicas
    max_count=$replicas
  fi

  echo "$min_count $max_count"
}

process_component() {
  local file="$1"
  local comp="$2"

  enabled=$(yq eval ".${comp}.enabled // \"true\"" "$file")
  [[ "$enabled" == "false" ]] && return

  # đź”Ą ICI ON UTILISE LA NOUVELLE FONCTION
  read cpu mem <<< "$(get_resources "$file" "$comp")"

  read min_count max_count <<< "$(get_counts "$file" "$comp")"

  cpu_m=$(cpu_to_m "$cpu")
  mem_mi=$(mem_to_mi "$mem")

  min_cpu=$(echo "$cpu_m * $min_count" | bc)
  min_mem=$(echo "$mem_mi * $min_count" | bc)

  max_cpu=$(echo "$cpu_m * $max_count" | bc)
  max_mem=$(echo "$mem_mi * $max_count" | bc)

  printf "%-12s | pod: %4sm / %4sMi | pods(min/max): %2s/%2s | total(min): %6sm / %6sMi | total(max): %6sm / %6sMi\n" \
    "$comp" "$cpu_m" "$mem_mi" "$min_count" "$max_count" "$min_cpu" "$min_mem" "$max_cpu" "$max_mem"

  TOTAL_MIN_CPU=$(echo "$TOTAL_MIN_CPU + $min_cpu" | bc)
  TOTAL_MIN_MEM=$(echo "$TOTAL_MIN_MEM + $min_mem" | bc)
  TOTAL_MAX_CPU=$(echo "$TOTAL_MAX_CPU + $max_cpu" | bc)
  TOTAL_MAX_MEM=$(echo "$TOTAL_MAX_MEM + $max_mem" | bc)

  INSTANCE_MIN_CPU=$(echo "$INSTANCE_MIN_CPU + $min_cpu" | bc)
  INSTANCE_MIN_MEM=$(echo "$INSTANCE_MIN_MEM + $min_mem" | bc)
  INSTANCE_MAX_CPU=$(echo "$INSTANCE_MAX_CPU + $max_cpu" | bc)
  INSTANCE_MAX_MEM=$(echo "$INSTANCE_MAX_MEM + $max_mem" | bc)
}

process_env() {
  local ENV="$1"

  [[ ! -d "instances/$ENV" ]] && return

  echo ""
  echo "================ ENV: $ENV ================"

  for instance in instances/$ENV/*; do
    INSTANCE_NAME=$(basename "$instance")

    echo ""
    echo "INSTANCE: $INSTANCE_NAME"
    echo "------------------------------------------------------------"

    INSTANCE_MIN_CPU=0
    INSTANCE_MIN_MEM=0
    INSTANCE_MAX_CPU=0
    INSTANCE_MAX_MEM=0

    TMP=$(mktemp)

    # fusion global + instance
    if [[ "$INSTANCE_NAME" == "meta" ]]; then
      cp "$instance/values.yaml" "$TMP"
    else
      yq eval-all 'select(fileIndex == 0) *+ select(fileIndex == 1)' \
        "$GLOBAL_VALUES" "$instance/values.yaml" > "$TMP"
    fi

    for comp in server repoServer controller dex; do
      process_component "$TMP" "$comp"
    done

    process_component "$TMP" "redis"

    ha_enabled=$(yq eval '.ha.enabled // "false"' "$TMP")
    if [[ "$ha_enabled" == "true" ]]; then
      process_component "$TMP" "ha"
    fi

    echo "------------------------------------------------------------"
    echo "INSTANCE TOTAL (MIN): ${INSTANCE_MIN_CPU}m CPU / ${INSTANCE_MIN_MEM}Mi MEM"
    echo "INSTANCE TOTAL (MAX): ${INSTANCE_MAX_CPU}m CPU / ${INSTANCE_MAX_MEM}Mi MEM"

    rm -f "$TMP"
  done
}

# đźš€ EXECUTION
for env in "${ENVS[@]}"; do
  process_env "$env"
done

echo ""
echo "================ GLOBAL TOTAL ================="
echo "MIN CPU: ${TOTAL_MIN_CPU}m ($(echo "$TOTAL_MIN_CPU/1000" | bc -l) cores)"
echo "MIN MEM: ${TOTAL_MIN_MEM}Mi ($(echo "$TOTAL_MIN_MEM/1024" | bc -l) Gi)"
echo ""
echo "MAX CPU: ${TOTAL_MAX_CPU}m ($(echo "$TOTAL_MAX_CPU/1000" | bc -l) cores)"
echo "MAX MEM: ${TOTAL_MAX_MEM}Mi ($(echo "$TOTAL_MAX_MEM/1024" | bc -l) Gi)"
