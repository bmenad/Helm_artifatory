#!/usr/bin/env bash
set -euo pipefail

CHART_PATH="./helm"
INSTANCES_DIR="./instances"

GLOBAL_MIN_CPU=0
GLOBAL_MAX_CPU=0
GLOBAL_MIN_MEM=0
GLOBAL_MAX_MEM=0

cpu_to_m() {
  local cpu="$1"
  if [[ "$cpu" == *m ]]; then
    echo "${cpu%m}"
  else
    awk "BEGIN {printf \"%d\", $cpu * 1000}"
  fi
}

mem_to_mi() {
  local mem="$1"
  if [[ "$mem" == *Gi ]]; then
    awk "BEGIN {printf \"%d\", ${mem%Gi} * 1024}"
  elif [[ "$mem" == *Mi ]]; then
    echo "${mem%Mi}"
  else
    echo "0"
  fi
}

get_cpu() {
  echo "$1" | jq -r '.requests.cpu // .limits.cpu // "0"'
}

get_mem() {
  echo "$1" | jq -r '.requests.memory // .limits.memory // "0"'
}

process_instance() {
  local env="$1"
  local instance="$2"
  local values_file="$3"

  echo ""
  echo "=============================="
  echo "Instance: $instance ($env)"
  echo "=============================="

  printf "%-12s %-10s %-10s %-10s %-10s %-10s\n" "POD" "CPU(m)" "MEM(Mi)" "COUNT" "MIN" "MAX"
  echo "---------------------------------------------------------------------"

  rendered=$(helm template "$instance" "$CHART_PATH" \
    -f "$CHART_PATH/values.yaml" \
    -f "$values_file")

  inst_min_cpu=0
  inst_max_cpu=0
  inst_min_mem=0
  inst_max_mem=0

  while read -r cr; do

    # -------- controller --------
    ctrl=$(echo "$cr" | jq '.spec.controller.resources // {}')
    replicas=$(echo "$cr" | jq -r '.spec.controller.sharding.replicas // 1')

    cpu=$(cpu_to_m "$(get_cpu "$ctrl")")
    mem=$(mem_to_mi "$(get_mem "$ctrl")")

    printf "%-12s %-10s %-10s %-10s %-10s %-10s\n" "controller" "$cpu" "$mem" "$replicas" "$replicas" "$replicas"

    inst_min_cpu=$((inst_min_cpu + cpu * replicas))
    inst_max_cpu=$((inst_max_cpu + cpu * replicas))
    inst_min_mem=$((inst_min_mem + mem * replicas))
    inst_max_mem=$((inst_max_mem + mem * replicas))

    # -------- repo --------
    repo=$(echo "$cr" | jq '.spec.repo.resources // {}')
    replicas=$(echo "$cr" | jq -r '.spec.repo.replicas // 1')

    cpu=$(cpu_to_m "$(get_cpu "$repo")")
    mem=$(mem_to_mi "$(get_mem "$repo")")

    printf "%-12s %-10s %-10s %-10s %-10s %-10s\n" "repo" "$cpu" "$mem" "$replicas" "$replicas" "$replicas"

    inst_min_cpu=$((inst_min_cpu + cpu * replicas))
    inst_max_cpu=$((inst_max_cpu + cpu * replicas))
    inst_min_mem=$((inst_min_mem + mem * replicas))
    inst_max_mem=$((inst_max_mem + mem * replicas))

    # -------- server (HPA) --------
    server=$(echo "$cr" | jq '.spec.server.resources // {}')

    min_rep=$(echo "$cr" | jq -r '.spec.server.autoscaling.minReplicas // .spec.server.replicas // 1')
    max_rep=$(echo "$cr" | jq -r '.spec.server.autoscaling.maxReplicas // $min_rep')

    cpu=$(cpu_to_m "$(get_cpu "$server")")
    mem=$(mem_to_mi "$(get_mem "$server")")

    printf "%-12s %-10s %-10s %-10s %-10s %-10s\n" "server" "$cpu" "$mem" "$min_rep" "$min_rep" "$max_rep"

    inst_min_cpu=$((inst_min_cpu + cpu * min_rep))
    inst_max_cpu=$((inst_max_cpu + cpu * max_rep))
    inst_min_mem=$((inst_min_mem + mem * min_rep))
    inst_max_mem=$((inst_max_mem + mem * max_rep))

    # -------- redis --------
    redis=$(echo "$cr" | jq '.spec.redis.resources // {}')
    replicas=$(echo "$cr" | jq -r '.spec.redis.replicas // 1')

    cpu=$(cpu_to_m "$(get_cpu "$redis")")
    mem=$(mem_to_mi "$(get_mem "$redis")")

    printf "%-12s %-10s %-10s %-10s %-10s %-10s\n" "redis" "$cpu" "$mem" "$replicas" "$replicas" "$replicas"

    inst_min_cpu=$((inst_min_cpu + cpu * replicas))
    inst_max_cpu=$((inst_max_cpu + cpu * replicas))
    inst_min_mem=$((inst_min_mem + mem * replicas))
    inst_max_mem=$((inst_max_mem + mem * replicas))

  done < <(
    echo "$rendered" | yq -o=json '.' | jq -c 'select(.kind=="ArgoCD")'
  )

  echo "---------------------------------------------------------------------"
  echo "Instance TOTAL MIN  → CPU: ${inst_min_cpu}m | MEM: ${inst_min_mem}Mi"
  echo "Instance TOTAL MAX  → CPU: ${inst_max_cpu}m | MEM: ${inst_max_mem}Mi"

  GLOBAL_MIN_CPU=$((GLOBAL_MIN_CPU + inst_min_cpu))
  GLOBAL_MAX_CPU=$((GLOBAL_MAX_CPU + inst_max_cpu))
  GLOBAL_MIN_MEM=$((GLOBAL_MIN_MEM + inst_min_mem))
  GLOBAL_MAX_MEM=$((GLOBAL_MAX_MEM + inst_max_mem))
}

# -----------------------------
# MAIN
# -----------------------------
for env in nprd prod; do
  echo ""
  echo "################################"
  echo "ENV: $env"
  echo "################################"

  for instance_dir in "$INSTANCES_DIR/$env"/*; do
    instance=$(basename "$instance_dir")
    values_file="$instance_dir/values.yaml"

    [[ -f "$values_file" ]] && process_instance "$env" "$instance" "$values_file"
  done
done

echo ""
echo "======================================"
echo "GLOBAL TOTAL (ALL INSTANCES)"
echo "======================================"
echo "MIN CPU: ${GLOBAL_MIN_CPU}m"
echo "MAX CPU: ${GLOBAL_MAX_CPU}m"
echo "MIN MEM: ${GLOBAL_MIN_MEM}Mi"
echo "MAX MEM: ${GLOBAL_MAX_MEM}Mi"
